{
  "version": 2,
  "builds": [
    {
      "src": "api/compute.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/compute.js"
    },
    {
      "src": "/status",
      "dest": "/api/compute.js"
    },
    {
      "src": "/compute",
      "dest": "/public/compute.html"
    },
    {
      "src": "/list-resource",
      "dest": "/public/list-resource.html"
    },
    {
      "src": "/operator",
      "dest": "/public/operator.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
